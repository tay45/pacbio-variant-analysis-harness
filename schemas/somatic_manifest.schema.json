{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "somatic_manifest.schema.json",
  "title": "Phase 2D Somatic Manifest Row",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "pair_id",
    "subject_id",
    "tumor_sample_id",
    "tumor_specimen_id",
    "tumor_input_type",
    "tumor_input_path",
    "tumor_index_path",
    "normal_sample_id",
    "normal_specimen_id",
    "normal_input_type",
    "normal_input_path",
    "normal_index_path",
    "reference_id",
    "analysis_mode",
    "enabled"
  ],
  "properties": {
    "pair_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"},
    "subject_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"},
    "tumor_sample_id": {"type": "string"},
    "tumor_specimen_id": {"type": "string"},
    "tumor_input_type": {"enum": ["BAM", "CRAM", "bam", "cram"]},
    "tumor_input_path": {"type": "string"},
    "tumor_index_path": {"type": "string"},
    "normal_sample_id": {"type": "string"},
    "normal_specimen_id": {"type": "string"},
    "normal_input_type": {"type": "string"},
    "normal_input_path": {"type": "string"},
    "normal_index_path": {"type": "string"},
    "reference_id": {"type": "string"},
    "analysis_mode": {"enum": ["tumor_normal", "tumor_only"]},
    "enabled": {"type": "string"},
    "tumor_coverage": {"type": ["string", "number", "null"]},
    "normal_coverage": {"type": ["string", "number", "null"]},
    "tumor_purity": {"type": ["string", "number", "null"]},
    "tumor_contamination": {"type": ["string", "number", "null"]},
    "normal_contamination": {"type": ["string", "number", "null"]},
    "tumor_ploidy": {"type": ["string", "number", "null"]},
    "tumor_only_acknowledgment": {"type": ["string", "null"]}
  }
}
